\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  \relax \fontsize  {8}{9.5pt}\selectfont  \abovedisplayskip 6\p@ plus2\p@ minus4\p@ \belowdisplayskip \abovedisplayskip \abovedisplayshortskip \z@ plus\p@ \belowdisplayshortskip 3\p@ plus\p@ minus2\p@ \def \leftmargin \leftmargini \topsep 4\p@ plus2\p@ minus2\p@ \parsep 2\p@ plus\p@ minus\p@ \itemsep \parsep {\leftmargin \leftmargini \topsep 3\p@ plus\p@ minus\p@ \parsep 2\p@ plus\p@ minus\p@ \itemsep \parsep }\textbf  {Implied timescales convergence test.} First three implied timescales as a function of the MSM lagtime. Colors denote the four combinations of feature set and dimensionality reduction method, while marker styles indicate the number of microstates used in the state-space discretization. The shaded region corresponds to $t_i \leq \tau $, where $t_i$ is the implied timescale and $\tau $ the MSM lagtime. Timescales falling within this region are not resolved by the model, as the associated relaxation process occurs on a timescale shorter than a single Markov-chain transition step. {\color  {orange} TODO: make fig more readable, maybe split into rows} {\color  {orange} TODO: add uncertainties using bootstrapping} }}{4}{figure.caption.13}\protected@file@percent }
\newlabel{fig:implied_timescales}{{2}{4}{\footnotesize \textbf {Implied timescales convergence test.} First three implied timescales as a function of the MSM lagtime. Colors denote the four combinations of feature set and dimensionality reduction method, while marker styles indicate the number of microstates used in the state-space discretization. The shaded region corresponds to $t_i \leq \tau $, where $t_i$ is the implied timescale and $\tau $ the MSM lagtime. Timescales falling within this region are not resolved by the model, as the associated relaxation process occurs on a timescale shorter than a single Markov-chain transition step. {\color {orange} TODO: make fig more readable, maybe split into rows} {\color {orange} TODO: add uncertainties using bootstrapping}}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \relax \fontsize  {8}{9.5pt}\selectfont  \abovedisplayskip 6\p@ plus2\p@ minus4\p@ \belowdisplayskip \abovedisplayskip \abovedisplayshortskip \z@ plus\p@ \belowdisplayshortskip 3\p@ plus\p@ minus2\p@ \def \leftmargin \leftmargini \topsep 4\p@ plus2\p@ minus2\p@ \parsep 2\p@ plus\p@ minus\p@ \itemsep \parsep {\leftmargin \leftmargini \topsep 3\p@ plus\p@ minus\p@ \parsep 2\p@ plus\p@ minus\p@ \itemsep \parsep }\textbf  {Results of the autocorrelation test:} { Autocorrelation function of the root mean square deviation (RMSD) from the crystal structure, as obtained from the molecular dynamics trajectory (blue) and predicted by the four MSMs (orange, green, red and purple). \color  {orange} TODO: add uncertainties using bootstrapping} }}{4}{figure.caption.14}\protected@file@percent }
\newlabel{fig:autocorrelation}{{3}{4}{\footnotesize \textbf {Results of the autocorrelation test:} { Autocorrelation function of the root mean square deviation (RMSD) from the crystal structure, as obtained from the molecular dynamics trajectory (blue) and predicted by the four MSMs (orange, green, red and purple). \color {orange} TODO: add uncertainties using bootstrapping}}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \relax \fontsize  {8}{9.5pt}\selectfont  \abovedisplayskip 6\p@ plus2\p@ minus4\p@ \belowdisplayskip \abovedisplayskip \abovedisplayshortskip \z@ plus\p@ \belowdisplayshortskip 3\p@ plus\p@ minus2\p@ \def \leftmargin \leftmargini \topsep 4\p@ plus2\p@ minus2\p@ \parsep 2\p@ plus\p@ minus\p@ \itemsep \parsep {\leftmargin \leftmargini \topsep 3\p@ plus\p@ minus\p@ \parsep 2\p@ plus\p@ minus\p@ \itemsep \parsep }\textbf  {Comparison between the slowest MSM relaxation mode and a structural folding descriptor.} Top row: values of the first non-trivial eigenvector projected onto the first two components of the reduced coordinate space. Positive and negative components identify regions that exchange probability on the slowest resolved timescale of the Markov model. Bottom row: projection of the fraction of native contacts, Q, onto the same coordinates. The close correspondence between the eigenvector sign pattern and the distribution of $Q$ indicates that the slowest kinetic process captured by the MSM is associated with the folding-unfolding transition.}}{4}{figure.caption.15}\protected@file@percent }
\newlabel{fig:eigenvectors}{{4}{4}{\footnotesize \textbf {Comparison between the slowest MSM relaxation mode and a structural folding descriptor.} Top row: values of the first non-trivial eigenvector projected onto the first two components of the reduced coordinate space. Positive and negative components identify regions that exchange probability on the slowest resolved timescale of the Markov model. Bottom row: projection of the fraction of native contacts, Q, onto the same coordinates. The close correspondence between the eigenvector sign pattern and the distribution of $Q$ indicates that the slowest kinetic process captured by the MSM is associated with the folding-unfolding transition}{figure.caption.15}{}}
